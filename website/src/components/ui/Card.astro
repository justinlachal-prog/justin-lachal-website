---
interface Props {
  href?: string;
  class?: string;
}
const { href, class: className } = Astro.props;
const Tag = href ? 'a' : 'div';
---
<Tag
  href={href}
  class:list={[
    'block rounded-lg border border-grey-200 bg-white p-6 shadow-sm',
    href && 'hover:shadow-md hover:border-teal/30 transition-shadow',
    className,
  ]}
>
  <slot />
</Tag>
