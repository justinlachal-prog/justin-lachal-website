---
import { url } from '../../utils/url';

const navItems = [
  { label: 'Costing', href: url('/services/costing') },
  { label: 'Post-Implementation', href: url('/services/reviews') },
  { label: 'Governance', href: url('/services/performance') },
  { label: 'Strategy', href: url('/services/strategy') },
  { label: 'Finance Function', href: url('/services/finance-function') },
  { label: 'Workshops', href: url('/services/workshops') },
  { label: 'Contact', href: url('/contact') },
];

const currentPath = Astro.url.pathname;
---
<nav class="hidden md:flex items-center gap-6">
  {navItems.map(item => (
    <a
      href={item.href}
      class:list={[
        'text-xs font-medium transition-colors whitespace-nowrap',
        currentPath === item.href || currentPath.startsWith(item.href + '/')
          ? 'text-teal'
          : 'text-charcoal hover:text-teal',
      ]}
    >
      {item.label}
    </a>
  ))}
</nav>
